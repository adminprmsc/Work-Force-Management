      "name": "Audit Logs",
      "description": "Senior Manager only. Immutable trail of all user mutations.",
      "item": [
        {
          "name": "List Audit Logs",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "pm.test('Returns paginated result', () => {",
                  "  pm.expect(res.items).to.be.an('array');",
                  "  pm.expect(res.total).to.be.a('number');",
                  "  pm.expect(res.page).to.eql(1);",
                  "  pm.expect(res.limit).to.eql(20);",
                  "});",
                  "if (res.items.length > 0) {",
                  "  const log = res.items[0];",
                  "  pm.test('Audit log has required fields', () => {",
                  "    pm.expect(log).to.have.property('action');",
                  "    pm.expect(log).to.have.property('actor');",
                  "    pm.expect(log.actor).to.have.property('email');",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/audit-logs?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["audit-logs"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20", "description": "Max 100" }
              ]
            },
            "description": "Paginated audit trail. Actions: `USER_CREATED`, `USER_UPDATED`, `USER_DELETED`, `USER_ACTIVATED`, `USER_DEACTIVATED`, `USER_CREDENTIALS_RESET`.\n\n**Response:**\n```json\n{\n  \"items\": [{ \"id\", \"action\", \"resourceType\", \"resourceId\", \"metadata\", \"createdAt\", \"actor\": { \"id\", \"email\", \"username\" } }],\n  \"total\", \"page\", \"limit\"\n}\n```"
          }
