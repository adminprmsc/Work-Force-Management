NODE_ENV=development

# npm run docker:dev — host port for the API container (container listens on 3000 internally)
API_PORT=3001
# npm run dev:local — host port for Nest on your machine (must NOT equal API_PORT)
PORT=3000

# PostgreSQL
POSTGRES_USER=wfm_user
POSTGRES_PASSWORD=wfm_local_password
POSTGRES_DB=wfm_db
POSTGRES_PORT=5434

# Host machine → DB (pgAdmin, Prisma CLI, local npm run)
DATABASE_URL=postgresql://wfm_user:wfm_local_password@localhost:5434/wfm_db

# Inside Docker Compose, DATABASE_URL is overridden to use hostname "postgres".

JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=1d

# Comma-separated browser origins allowed to call the API (CORS)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Seed — Senior Manager E&S + 16 RA E&S (run: npm run db:seed)
SEED_SENIOR_MANAGER_EMAIL=senior.manager@wfm.local
SEED_SENIOR_MANAGER_USERNAME=senior_manager_es
SEED_SENIOR_MANAGER_PASSWORD=SeniorManager@123
SEED_RA_ES_PASSWORD=RaEs@123

# ── pgAdmin (General → Name: "WFM Local") ───────────────────────────────────
# Host: localhost | Port: 5434 | Database: wfm_db
# Username: wfm_user | Password: wfm_local_password
