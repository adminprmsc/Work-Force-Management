# ──────────────────────────────────────────────────────────────────────────────
# Work Force Management — PRODUCTION environment
#
#   1. Copy this file to `.env`  →  cp .env.prod.example .env
#   2. Replace every CHANGE_ME value with a strong secret.
#   3. NEVER commit the real .env (it is git-ignored).
# ──────────────────────────────────────────────────────────────────────────────

# ── Database (stays private inside the Docker network) ───────────────────────
POSTGRES_USER=wfm_user
POSTGRES_PASSWORD=wfm_user-prmsc-12345!
POSTGRES_DB=wfm_db

# ── API ──────────────────────────────────────────────────────────────────────
# Generate a long random secret, e.g.  openssl rand -base64 48
JWT_SECRET=HBTapFPnKmtwN58uJPVUh6Pr1kfkM8Z1Lp3p7sh9X70tlH0OVaz9WkJAuKD
JWT_EXPIRES_IN=1d

# Same-origin in production, so CORS is effectively unused. If you ever serve
# the API on a different host, list allowed origins here (comma-separated).
CORS_ORIGINS=

# ── Edge (Nginx) ─────────────────────────────────────────────────────────────
# Public HTTP port on the VM. Keep 80 behind a TLS terminator/load balancer,
# or put a certbot/Caddy proxy in front (see DEPLOYMENT.md).
WEB_HTTP_PORT=80

# Build-time API base path baked into the SPA. Same-origin path proxied by
# Nginx — leave as /api unless you split the frontend onto its own domain.
VITE_API_BASE_URL=/api

# ── Seed (idempotent — safe to run on every deploy) ──────────────────────────
# Set RUN_SEED=false after the first successful deploy if you do not want the
# baseline accounts re-asserted on subsequent deploys.
RUN_SEED=true
SEED_SENIOR_MANAGER_EMAIL=senior.manager@ens.com
SEED_SENIOR_MANAGER_USERNAME=senior_manager_es
SEED_SENIOR_MANAGER_PASSWORD=senior_manager_es-12345!
SEED_RA_ES_PASSWORD=ra_es-12345!
